@implements IAsyncDisposable
@inject ITermCardService TermCardService
@inject ITranslationService TranslationService
@inject IJSRuntime JS

<div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.65);">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(IsEditMode ? "Edit card" : "New card")</h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">@LanguageHelper.GetDisplayName(Language1)</label>

                        <div class="mb-2">
                            <div class="input-group">
                                <input type="text" id="text1" class="form-control"
                                       dir="@LanguageHelper.GetTextDirection(Language1)"
                                       placeholder="@($"Text ({LanguageHelper.GetDisplayName(Language1)})")"
                                       maxlength="50"
                                       value="@_text1"
                                       @oninput="OnText1Input" />
                                <button type="button"
                                        class="@MicButtonClass"
                                        @onclick="ToggleRecordingAsync"
                                        title="@MicButtonTitle">@MicButtonIcon</button>
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        disabled="@(string.IsNullOrWhiteSpace(_text1) && string.IsNullOrEmpty(_audio1DataUrl))"
                                        @onclick="SpeakValue1Async"
                                        title="Play">🔊</button>
                            </div>
                            @if (_text1.Length > 50)
                            {
                                <div class="text-danger small mt-1">Maximum 50 characters</div>
                            }
                            @if (_isRecording)
                            {
                                <div class="text-danger small mt-1">@_recordSeconds/@MaxRecordSeconds s</div>
                            }
                            @if (!string.IsNullOrEmpty(_recordError))
                            {
                                <div class="text-danger small mt-1">@_recordError</div>
                            }
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">@LanguageHelper.GetDisplayName(Language2)</label>

                        <div class="mb-2">
                            <div class="input-group">
                                <input type="text" id="text2" class="form-control"
                                       dir="@LanguageHelper.GetTextDirection(Language2)"
                                       placeholder="@($"Text ({LanguageHelper.GetDisplayName(Language2)})")"
                                       maxlength="50"
                                       value="@_text2"
                                       @oninput="OnText2Input" />
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        disabled="@string.IsNullOrWhiteSpace(_text2)"
                                        @onclick="() => SpeakAsync(_text2, Language2)"
                                        title="Play">🔊</button>
                            </div>
                            @if (_text2.Length > 50)
                            {
                                <div class="text-danger small mt-1">Maximum 50 characters</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label">Image</label>
                    @if (!string.IsNullOrEmpty(_imageDataUrl))
                    {
                        <div class="position-relative d-inline-block">
                            <img src="@_imageDataUrl" class="img-thumbnail" style="max-height:160px;" alt="" />
                            <button type="button"
                                    class="btn btn-sm btn-danger position-absolute top-0 end-0"
                                    @onclick="() => _imageDataUrl = null">✕</button>
                        </div>
                    }
                    else
                    {
                        <div class="image-placeholder" id="paste-zone">
                            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                                <path d="M21 19V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" />
                            </svg>
                            <span>No image</span>
                        </div>
                    }
                    <InputFile id="image-upload"
                               class="form-control form-control-sm mt-2"
                               accept="image/*"
                               OnChange="HandleImageUpload" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="OnClose">Cancel</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="HandleSave"
                        disabled="@(!IsValid)">Save</button>
                @if (!IsEditMode)
                {
                    <button type="button" class="btn btn-success" @onclick="HandleSaveAndContinue"
                            disabled="@(!IsValid)">Save and continue</button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string UserId { get; set; } = string.Empty;
    [Parameter, EditorRequired] public Language Language1 { get; set; }
    [Parameter, EditorRequired] public Language Language2 { get; set; }
    [Parameter] public TermCard? ExistingCard { get; set; }
    [Parameter] public EventCallback<TermCard> OnSave { get; set; }
    [Parameter] public EventCallback<TermCard> OnSaveAndContinue { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool IsEditMode => ExistingCard is not null;
    // Tracks the card we last initialized fields from, so we re-populate only when the card actually changes
    private Guid? _initializedCardId;

    private const int TranslationDebounceMs = 700;
    private const int MaxRecordSeconds = 10;

    private string _text1 = string.Empty;
    private string _text2 = string.Empty;
    private string? _imageDataUrl;
    private string? _audio1DataUrl;
    private bool _isRecording;
    private int _recordSeconds;
    private string? _recordError;
    private CancellationTokenSource? _recordTickerCts;
    private DotNetObjectReference<TermCardModal>? _dotNetRef;
    // Signals that the in-flight recording has been finalized by the browser
    // (either OnRecordingComplete or OnRecordingError fired). Used by Save/Save and
    // continue to wait for the audio bytes before persisting the card.
    private TaskCompletionSource? _recordStopTcs;
    private const int RecordStopTimeoutMs = 5000;

    private string MicButtonClass => _isRecording
        ? "btn btn-danger"
        : (!string.IsNullOrEmpty(_audio1DataUrl) ? "btn btn-success" : "btn btn-outline-secondary");

    private string MicButtonIcon => _isRecording ? "⏺" : "🎤";

    private string MicButtonTitle => _isRecording
        ? "Stop recording"
        : (!string.IsNullOrEmpty(_audio1DataUrl) ? "Re-record audio" : "Record audio");

    // Tracks the last value we auto-filled into each field, so we can update it
    // again on subsequent edits, but never overwrite text the user typed manually.
    private string _lastAutoText1 = string.Empty;
    private string _lastAutoText2 = string.Empty;
    private CancellationTokenSource? _debounceCts;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_text1) && _text1.Length <= 50 &&
        !string.IsNullOrWhiteSpace(_text2) && _text2.Length <= 50;

    protected override void OnParametersSet()
    {
        if (ExistingCard is not null && _initializedCardId != ExistingCard.Id)
        {
            _text1 = ExistingCard.Value1.Text;
            _text2 = ExistingCard.Value2.Text;
            _imageDataUrl = ExistingCard.ImageDataUrl;
            // Existing audio is referenced by its file path; a re-recording will replace it with a data: URL
            _audio1DataUrl = ExistingCard.Value1.AudioPath;
            _initializedCardId = ExistingCard.Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("cardsApp.initPasteHandlers", _dotNetRef);
            await JS.InvokeVoidAsync("cardsApp.focusElement", "text1");
        }
    }

    [JSInvokable]
    public void OnImagePasted(string dataUrl)
    {
        _imageDataUrl = dataUrl;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null || !file.ContentType.StartsWith("image/")) return;

        const long maxSize = 5 * 1024 * 1024;
        await using var stream = file.OpenReadStream(maxSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        _imageDataUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private async Task SpeakAsync(string text, Language language)
    {
        if (string.IsNullOrWhiteSpace(text)) return;
        await JS.InvokeVoidAsync("cardsApp.speakText", text, LanguageHelper.GetSpeechCode(language));
    }

    private async Task SpeakValue1Async()
    {
        if (!string.IsNullOrEmpty(_audio1DataUrl))
        {
            await JS.InvokeVoidAsync("cardsApp.playRecording", _audio1DataUrl);
            return;
        }
        await SpeakAsync(_text1, Language1);
    }

    private async Task ToggleRecordingAsync()
    {
        if (_isRecording)
        {
            await JS.InvokeVoidAsync("cardsApp.stopRecording");
            return;
        }

        _recordError = null;
        _recordSeconds = 0;
        _isRecording = true;
        StateHasChanged();

        StartRecordTicker();

        var started = await JS.InvokeAsync<bool>(
            "cardsApp.startRecording",
            _dotNetRef,
            nameof(OnRecordingComplete),
            MaxRecordSeconds,
            nameof(OnRecordingError));

        if (!started)
        {
            // Error callback already fired and reset state
            return;
        }
    }

    private void StartRecordTicker()
    {
        StopRecordTicker();
        _recordTickerCts = new CancellationTokenSource();
        var token = _recordTickerCts.Token;
        _ = RunRecordTickerAsync(token);
    }

    private async Task RunRecordTickerAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested && _recordSeconds < MaxRecordSeconds)
            {
                await Task.Delay(1000, ct);
                if (ct.IsCancellationRequested) return;
                _recordSeconds++;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private void StopRecordTicker()
    {
        _recordTickerCts?.Cancel();
        _recordTickerCts?.Dispose();
        _recordTickerCts = null;
    }

    [JSInvokable]
    public Task OnRecordingComplete(string? dataUrl)
    {
        _audio1DataUrl = string.IsNullOrEmpty(dataUrl) ? _audio1DataUrl : dataUrl;
        _isRecording = false;
        _recordSeconds = 0;
        StopRecordTicker();
        _recordStopTcs?.TrySetResult();
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnRecordingError(string message)
    {
        _recordError = string.IsNullOrWhiteSpace(message) ? "Microphone unavailable" : message;
        _isRecording = false;
        _recordSeconds = 0;
        StopRecordTicker();
        _recordStopTcs?.TrySetResult();
        return InvokeAsync(StateHasChanged);
    }

    // Stops the in-flight recording and waits for OnRecordingComplete (or OnRecordingError)
    // to fire so the audio data URL is populated before the caller proceeds.
    private async Task EnsureRecordingStoppedAsync()
    {
        if (!_isRecording) return;

        _recordStopTcs = new TaskCompletionSource(TaskCreationOptions.RunContinuationsAsynchronously);
        try
        {
            await JS.InvokeVoidAsync("cardsApp.stopRecording");
        }
        catch (JSDisconnectedException)
        {
            return;
        }

        // Bound the wait so a stuck MediaRecorder cannot hang the Save action.
        await Task.WhenAny(_recordStopTcs.Task, Task.Delay(RecordStopTimeoutMs));
        _recordStopTcs = null;
    }

    private void OnText1Input(ChangeEventArgs e)
    {
        _text1 = e.Value?.ToString() ?? string.Empty;
        ScheduleTranslation(sourceField: 1);
    }

    private void OnText2Input(ChangeEventArgs e)
    {
        _text2 = e.Value?.ToString() ?? string.Empty;
        ScheduleTranslation(sourceField: 2);
    }

    private void ScheduleTranslation(int sourceField)
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        _ = TranslateAfterDelayAsync(sourceField, token);
    }

    private async Task TranslateAfterDelayAsync(int sourceField, CancellationToken ct)
    {
        try
        {
            await Task.Delay(TranslationDebounceMs, ct);
            await PerformTranslationAsync(sourceField, ct);
        }
        catch (OperationCanceledException) { }
    }

    private async Task PerformTranslationAsync(int sourceField, CancellationToken ct)
    {
        if (sourceField == 1)
        {
            var source = _text1;
            if (string.IsNullOrWhiteSpace(source)) return;
            // Don't overwrite text the user typed manually into the target field
            if (!string.IsNullOrEmpty(_text2) && _text2 != _lastAutoText2) return;

            var translated = await TranslationService.TranslateAsync(source, Language1, Language2, ct);
            if (ct.IsCancellationRequested || string.IsNullOrEmpty(translated)) return;
            // Source may have changed while we were waiting for the response
            if (_text1 != source) return;

            _text2 = translated;
            _lastAutoText2 = translated;
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            var source = _text2;
            if (string.IsNullOrWhiteSpace(source)) return;
            if (!string.IsNullOrEmpty(_text1) && _text1 != _lastAutoText1) return;

            var translated = await TranslationService.TranslateAsync(source, Language2, Language1, ct);
            if (ct.IsCancellationRequested || string.IsNullOrEmpty(translated)) return;
            if (_text2 != source) return;

            _text1 = translated;
            _lastAutoText1 = translated;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleSave()
    {
        if (!IsValid) return;
        await EnsureRecordingStoppedAsync();
        var card = await PersistCardAsync();
        if (card is null) return;
        await OnSave.InvokeAsync(card);
    }

    private async Task HandleSaveAndContinue()
    {
        if (!IsValid || IsEditMode) return;
        await EnsureRecordingStoppedAsync();
        var card = await PersistCardAsync();
        if (card is null) return;
        ResetForm();
        await OnSaveAndContinue.InvokeAsync(card);
        await JS.InvokeVoidAsync("cardsApp.focusElement", "text1");
    }

    private async Task<TermCard?> PersistCardAsync()
    {
        if (IsEditMode && ExistingCard is not null)
        {
            return await TermCardService.UpdateAsync(
                ExistingCard.Id,
                _text1, _text2,
                _imageDataUrl,
                _audio1DataUrl);
        }

        return await TermCardService.CreateAsync(
            UserId,
            Language1, Language2,
            _text1, _text2,
            _imageDataUrl,
            _audio1DataUrl);
    }

    private void ResetForm()
    {
        _debounceCts?.Cancel();
        _text1 = string.Empty;
        _text2 = string.Empty;
        _imageDataUrl = null;
        _audio1DataUrl = null;
        _isRecording = false;
        _recordSeconds = 0;
        _recordError = null;
        StopRecordTicker();
        _lastAutoText1 = string.Empty;
        _lastAutoText2 = string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        StopRecordTicker();
        try
        {
            if (_isRecording)
            {
                await JS.InvokeVoidAsync("cardsApp.stopRecording");
            }
            await JS.InvokeVoidAsync("cardsApp.disposePasteHandlers");
        }
        catch (JSDisconnectedException) { }
        _dotNetRef?.Dispose();
    }
}

@inject IAppInfoService AppInfo
@inject ITermCardService TermCardService
@inject NavigationManager Navigation
@implements IDisposable

<div class="sidebar-top">
    <a class="brand" href="">
        <span class="brand-mark" aria-hidden="true">
            <span class="brand-dot"></span>
            <span class="brand-dot"></span>
        </span>
        <span class="brand-text">Cards</span>
    </a>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />
</div>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav-root">
        <div class="nav-section">
            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 3 3 11h2v9h5v-6h4v6h5v-9h2L12 3z" />
                        </svg>
                        <span>Collections</span>
                    </NavLink>

                    <NavLink class="nav-link" href="public">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6zm0 5h16v2H4v-2zm0 5h16v2H4v-2z" />
                        </svg>
                        <span>Public collections</span>
                    </NavLink>

                    <NavLink class="nav-link" href="collections/create">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5z" />
                        </svg>
                        <span>New collection</span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-link" href="public">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6zm0 5h16v2H4v-2zm0 5h16v2H4v-2z" />
                        </svg>
                        <span>Public collections</span>
                    </NavLink>

                    <a class="nav-link" href="login">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M10 17l1.41-1.41L7.83 12H20v-2H7.83l3.58-3.59L10 5l-6 6 6 6zM4 4h6V2H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h6v-2H4V4z" />
                        </svg>
                        <span>Sign in</span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-section nav-section-srs">
                    <div class="nav-section-label">SRS levels</div>
                    @foreach (var level in _srsLevels)
                    {
                        var levelNum = (int)level;
                        var count = _counts.TryGetValue(level, out var c) ? c : 0;
                        var label = GetSrsLabel(level);
                        if (count == 0)
                        {
                            <span class="nav-link nav-link-disabled" title="No cards at this level">
                                <span class="nav-level-num">@levelNum</span>
                                <span class="nav-link-text">@label</span>
                                <span class="nav-count">0</span>
                            </span>
                        }
                        else
                        {
                            <NavLink class="nav-link" href="@($"training/srs/{levelNum}")">
                                <span class="nav-level-num">@levelNum</span>
                                <span class="nav-link-text">@label</span>
                                <span class="nav-count">@count</span>
                            </NavLink>
                        }
                    }
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <Authorized>
                <div class="nav-user-label">@context.User.Identity?.Name</div>
                <div class="nav-section nav-section-user">
                    <form action="logout" method="post" class="m-0 p-0">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link nav-logout-btn">
                            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M16 17v-2H9v-2h7V9l5 4-5 4zM14 3a2 2 0 0 1 2 2v3h-2V5H5v14h9v-3h2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9z" />
                            </svg>
                            <span>Sign out</span>
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-section">
                    <NavLink class="nav-link" href="backoffice">
                        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 5h8v6H3V5zm10 0h8v3h-8V5zm0 5h8v9h-8v-9zM3 13h8v6H3v-6z" />
                        </svg>
                        <span>BackOffice</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="app-stats">
            <span class="app-stats-label">Version</span>
            <span class="app-stats-value">@AppInfo.Version</span>
        </div>
    </nav>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly SrsLevel[] _srsLevels = Enum.GetValues<SrsLevel>();
    private Dictionary<SrsLevel, int> _counts = new();
    private string _userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        }
        await LoadCountsAsync();
        // Refresh counts on every navigation so the sidebar reflects card add/delete
        // and any future changes that affect SrsLevel distribution.
        Navigation.LocationChanged += OnLocationChanged;
    }

    private async Task LoadCountsAsync()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            _counts = new Dictionary<SrsLevel, int>();
            return;
        }
        var cards = await TermCardService.GetAllByUserAsync(_userId);
        _counts = _srsLevels.ToDictionary(l => l, l => cards.Count(c => c.SrsLevel == l));
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadCountsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static string GetSrsLabel(SrsLevel level) => level switch
    {
        SrsLevel.Level1 => "Initial fixation",
        SrsLevel.Level2 => "Hold in short-term memory",
        SrsLevel.Level3 => "First step to mid-term memory",
        SrsLevel.Level4 => "Strengthen connection",
        SrsLevel.Level5 => "Stability check",
        SrsLevel.Level6 => "Transfer to long-term memory",
        SrsLevel.Level7 => "Long-term retention",
        _ => level.ToString()
    };
}

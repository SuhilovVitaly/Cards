@inject IUserService UserService
@inject ICollectionService CollectionService
@inject ITermCardService TermCardService
@inject IAppInfoService AppInfo

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Cards</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column nav-root">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Collections
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="public">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Public collections
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="collections/create">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> New collection
                    </NavLink>
                </div>

                <div class="nav-item px-3 mt-3 user-info">
                    <div class="text-white-50 small">@context.User.Identity?.Name</div>
                    <form action="logout" method="post" class="m-0 p-0">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link nav-logout-btn">
                            <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Sign out
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="public">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Public collections
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link" href="login">
                        <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> Sign in
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="backoffice">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> BackOffice
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="app-stats px-3">
                    <div class="app-stats-row">
                        <span class="app-stats-label">Users</span>
                        <span class="app-stats-value">@_userCount</span>
                    </div>
                    <div class="app-stats-row">
                        <span class="app-stats-label">Collections</span>
                        <span class="app-stats-value">@_collectionCount</span>
                    </div>
                    <div class="app-stats-row">
                        <span class="app-stats-label">Cards</span>
                        <span class="app-stats-value">@_cardCount</span>
                    </div>
                    <div class="app-stats-row">
                        <span class="app-stats-label">Version</span>
                        <span class="app-stats-value">
                            @AppInfo.Version
                        </span>
                    </div>
                    <div class="app-stats-row">
                        <span class="app-stats-label">Last update</span>
                        <span class="app-stats-value">@_buildDateText</span>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private int _userCount;
    private int _collectionCount;
    private int _cardCount;
    private string _buildDateText = "—";

    protected override async Task OnInitializedAsync()
    {
        // Only admins see and load the stats block
        if (AuthState is null) return;

        var state = await AuthState;
        if (!state.User.IsInRole("Admin")) return;

        _userCount = await UserService.GetTotalCountAsync();
        _collectionCount = await CollectionService.GetTotalCountAsync();
        _cardCount = await TermCardService.GetTotalCountAsync();

        _buildDateText = AppInfo.BuildDateUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "—";
    }
}

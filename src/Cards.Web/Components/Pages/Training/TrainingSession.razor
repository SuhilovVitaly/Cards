@page "/training/{CollectionId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject ICollectionService CollectionService
@inject ITermCardService TermCardService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Training</PageTitle>

@if (_collection is null)
{
    <p class="text-muted"><em>Loading...</em></p>
}
else if (!_sessionActive)
{
    <div class="training-summary">
        <h2>Training complete</h2>
        <p class="training-counter mt-3" style="font-size:1.2rem;">
            <span class="c-correct">@_correct</span> /
            <span class="c-wrong">@_incorrect</span> /
            <span>@_total</span>
        </p>
        <a class="btn btn-primary mt-3" href="">Back to collections</a>
    </div>
}
else if (_currentCard is not null)
{
    <div class="training-screen">
        <div class="training-toolbar">
            <button type="button" class="btn-pill" @onclick="FinishSession">
                Finish
            </button>

            <div class="training-toolbar-center">
                <select class="form-select"
                        value="@_selectedLanguage" @onchange="OnLanguageChanged">
                    <option value="@_collection.Language1">
                        @LanguageHelper.GetDisplayName(_collection.Language1)
                    </option>
                    <option value="@_collection.Language2">
                        @LanguageHelper.GetDisplayName(_collection.Language2)
                    </option>
                </select>

                <span class="training-counter">
                    <span class="c-correct">@_correct</span> /
                    <span class="c-wrong">@_incorrect</span> /
                    <span>@_total</span>
                </span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                @if (_isOwner)
                {
                    <button type="button" class="btn-pill" @onclick="OpenAddCard">
                        + Card
                    </button>
                    <button type="button" class="btn-pill" @onclick="OpenEditCard"
                            disabled="@(_currentCard is null)">
                        Edit card
                    </button>
                    <button type="button" class="btn-pill-danger" @onclick="AskDeleteCard">
                        Delete card
                    </button>
                }
            </div>
        </div>

        @{
            var currentValue = GetCurrentValue();
            var currentLang = GetCurrentLanguage();
        }

        <div class="training-card">
            <div class="training-card-meta">
                Last viewed: @FormatLastViewed(_currentCard)
            </div>
            @if (!string.IsNullOrEmpty(_currentCard.ImageDataUrl))
            {
                <div class="training-card-image">
                    <img src="@_currentCard.ImageDataUrl" alt="" />
                </div>
            }
            <div class="training-card-text" dir="@LanguageHelper.GetTextDirection(currentLang)">
                @currentValue.Text
            </div>
            <button type="button" class="btn-audio"
                    @onclick="SpeakCurrentCardAsync"
                    title="Play">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3a4.5 4.5 0 0 0-2.5-4v8a4.5 4.5 0 0 0 2.5-4zM14 3.23v2.06a7 7 0 0 1 0 13.42v2.06a9 9 0 0 0 0-17.54z" />
                </svg>
            </button>
        </div>

        <div class="training-actions">
            @if (!_answered)
            {
                <button type="button" class="btn-cta-purple" @onclick="HandleDontRemember">
                    Show translation
                </button>
                <button type="button" class="btn-cta-green" @onclick="HandleRemember">
                    Next
                </button>
            }
            else
            {
                <button type="button" class="btn-cta-purple" @onclick="HandleBackToSource">
                    Back
                </button>
            }
        </div>
    </div>
}

@if (_showAddCard && _collection is not null)
{
    <TermCardModal
        UserId="@_userId"
        Language1="_collection.Language1"
        Language2="_collection.Language2"
        OnSave="HandleCardSaved"
        OnSaveAndContinue="HandleCardSavedAndContinue"
        OnClose="CloseAddCard" />
}

@if (_editCard is not null && _collection is not null)
{
    <TermCardModal
        UserId="@_userId"
        Language1="_collection.Language1"
        Language2="_collection.Language2"
        ExistingCard="_editCard"
        OnSave="HandleCardEdited"
        OnClose="CloseEditCard" />
}

@if (_showDeleteConfirm && _currentCard is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.65);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete card?</h5>
                    <button type="button" class="btn-close" @onclick="CancelDeleteCard"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">The card will be removed from this collection.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDeleteCard">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteCard">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid CollectionId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string _userId = string.Empty;
    private Collection? _collection;
    private Queue<TermCard> _queue = new();
    private TermCard? _currentCard;
    private Language _selectedLanguage;
    private bool _answered;
    private int _correct;
    private int _incorrect;
    private int _total;
    private bool _sessionActive;
    private bool _showAddCard;
    private TermCard? _editCard;
    private bool _showDeleteConfirm;
    private bool _needsAutoPlay;
    private bool _isOwner;
    // Tracks card ids for which a failure has already been counted in this session.
    // Each card contributes at most one to the incorrect counter, and once it is
    // here, a subsequent "Next" stops contributing to the correct counter.
    private readonly HashSet<Guid> _failedCardIds = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        _collection = await CollectionService.GetByIdAsync(CollectionId);
        // Anyone can train any collection. Block access only if the collection
        // does not exist or has no cards
        if (_collection is null || _collection.CardIds.Count == 0)
        {
            Navigation.NavigateTo("");
            return;
        }

        _isOwner = !string.IsNullOrEmpty(_userId) && _collection.UserId == _userId;

        _selectedLanguage = _collection.Language1;
        await StartSession();
        _needsAutoPlay = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsAutoPlay)
        {
            _needsAutoPlay = false;
            await SpeakCurrentCardAsync();
        }
    }

    private async Task StartSession()
    {
        if (_collection is null) return;

        var cards = await TermCardService.GetByIdsAsync(_collection.CardIds);
        var shuffled = Shuffle(cards);
        _queue = new Queue<TermCard>(shuffled);
        _total = shuffled.Count;
        _correct = 0;
        _incorrect = 0;
        _answered = false;
        _failedCardIds.Clear();
        _sessionActive = _queue.Count > 0;
        _currentCard = _queue.Count > 0 ? _queue.Dequeue() : null;
    }

    private async Task HandleRemember()
    {
        // Cards that have already been peeked do not contribute to the correct counter
        var pressedWithoutPeek = _currentCard is not null && !_failedCardIds.Contains(_currentCard.Id);
        if (pressedWithoutPeek)
        {
            _correct++;
            // "Next" without "Show translation" counts as a correct attempt toward the next SRS level
            _currentCard!.CorrectAttempts++;
        }

        // Persist the view timestamp only when the current user is the card's creator,
        // so the value reflects the owner's spaced-repetition history
        if (_currentCard is not null
            && !string.IsNullOrEmpty(_userId)
            && string.Equals(_currentCard.UserId, _userId, StringComparison.Ordinal))
        {
            var updated = await TermCardService.UpdateLastViewedAsync(
                _currentCard.Id,
                DateTime.UtcNow,
                _currentCard.CorrectAttempts);
            if (updated is not null)
            {
                _currentCard.LastViewedAt = updated.LastViewedAt;
                _currentCard.CorrectAttempts = updated.CorrectAttempts;
            }
        }

        AdvanceToNext();
        await SpeakCurrentCardAsync();
    }

    private string FormatLastViewed(TermCard? card)
    {
        if (card is null) return string.Empty;
        // Fall back to the collection creation time for cards that have never been viewed yet
        var timestamp = card.LastViewedAt ?? _collection?.CreatedAt ?? card.CreatedAt;
        return timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private async Task HandleDontRemember()
    {
        // Count the failure only the first time a given card is peeked
        if (_currentCard is not null && _failedCardIds.Add(_currentCard.Id))
        {
            _incorrect++;
        }
        _answered = true;
        await SpeakCurrentCardAsync();
    }

    private async Task HandleBackToSource()
    {
        // Flip the same card back to the originally selected language without advancing
        _answered = false;
        await SpeakCurrentCardAsync();
    }

    private void AdvanceToNext()
    {
        _answered = false;
        if (_queue.Count > 0)
        {
            _currentCard = _queue.Dequeue();
        }
        else
        {
            _sessionActive = false;
            _currentCard = null;
        }
    }

    private async Task FinishSession()
    {
        _sessionActive = false;
        await JS.InvokeVoidAsync("cardsApp.stopSpeaking");
    }

    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<Language>(e.Value?.ToString(), out var lang))
        {
            _selectedLanguage = lang;
            await StartSession();
            _needsAutoPlay = true;
        }
    }

    private async Task SpeakCurrentCardAsync()
    {
        if (_currentCard is null || _collection is null) return;
        var value = GetCurrentValue();
        var lang = GetCurrentLanguage();
        if (!string.IsNullOrEmpty(value.AudioPath))
        {
            await JS.InvokeVoidAsync("cardsApp.playRecording", value.AudioPath);
        }
        else
        {
            await JS.InvokeVoidAsync("cardsApp.speakText", value.Text, LanguageHelper.GetSpeechCode(lang));
        }
    }

    private Language GetCurrentLanguage()
    {
        if (_answered)
        {
            return _selectedLanguage == _collection!.Language1
                ? _collection.Language2
                : _collection.Language1;
        }
        return _selectedLanguage;
    }

    private TermValue GetCurrentValue()
    {
        if (_currentCard is null) return new TermValue();

        var lang = GetCurrentLanguage();
        return lang == _currentCard.Language1
            ? _currentCard.Value1
            : _currentCard.Value2;
    }

    private void OpenAddCard()
    {
        if (!_isOwner) return;
        _showAddCard = true;
    }

    private void CloseAddCard() => _showAddCard = false;

    private async Task HandleCardSaved(TermCard card)
    {
        if (!_isOwner) return;
        if (_collection is not null)
            await CollectionService.AddCardAsync(_collection.Id, card.Id);
        _showAddCard = false;
    }

    private async Task HandleCardSavedAndContinue(TermCard card)
    {
        if (!_isOwner) return;
        if (_collection is not null)
            await CollectionService.AddCardAsync(_collection.Id, card.Id);
    }

    private void OpenEditCard()
    {
        if (!_isOwner) return;
        if (_currentCard is null) return;
        _editCard = _currentCard;
    }

    private void CloseEditCard() => _editCard = null;

    private async Task HandleCardEdited(TermCard card)
    {
        if (!_isOwner)
        {
            _editCard = null;
            return;
        }

        // Replace the card we currently show and any pending occurrences in the queue
        if (_currentCard is not null && _currentCard.Id == card.Id)
        {
            _currentCard = card;
        }
        _queue = new Queue<TermCard>(_queue.Select(c => c.Id == card.Id ? card : c));

        _editCard = null;

        await JS.InvokeVoidAsync("cardsApp.stopSpeaking");
        await SpeakCurrentCardAsync();
    }

    private void AskDeleteCard()
    {
        if (!_isOwner) return;
        if (_currentCard is null) return;
        _showDeleteConfirm = true;
    }

    private void CancelDeleteCard() => _showDeleteConfirm = false;

    private async Task ConfirmDeleteCard()
    {
        if (!_isOwner)
        {
            _showDeleteConfirm = false;
            return;
        }

        if (_collection is null || _currentCard is null)
        {
            _showDeleteConfirm = false;
            return;
        }

        var deletedCardId = _currentCard.Id;
        await CollectionService.RemoveCardAsync(_collection.Id, deletedCardId);

        // Drop any future occurrences of the deleted card from the queue (defensive)
        _queue = new Queue<TermCard>(_queue.Where(c => c.Id != deletedCardId));

        _total = Math.Max(0, _total - 1);
        _showDeleteConfirm = false;

        await JS.InvokeVoidAsync("cardsApp.stopSpeaking");

        AdvanceToNext();

        if (_sessionActive)
        {
            await SpeakCurrentCardAsync();
        }
        else
        {
            // No cards left in the collection — return to collections list
            Navigation.NavigateTo("");
        }
    }

    private static List<T> Shuffle<T>(List<T> list)
    {
        var result = new List<T>(list);
        var rng = Random.Shared;
        for (int i = result.Count - 1; i > 0; i--)
        {
            int j = rng.Next(i + 1);
            (result[i], result[j]) = (result[j], result[i]);
        }
        return result;
    }
}

@page "/srs"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ITermCardService TermCardService

<PageTitle>SRS &mdash; spaced repetition</PageTitle>

<div class="page-header">
    <h1>SRS &mdash; spaced repetition</h1>
</div>

@if (!_loaded)
{
    <p class="text-muted"><em>Loading...</em></p>
}
else
{
    <div class="srs-levels-grid">
        @foreach (var level in _srsLevels)
        {
            var levelNum = (int)level;
            var count = _counts.TryGetValue(level, out var c) ? c : 0;
            var label = GetSrsLabel(level);
            var countText = $"{count} card{(count == 1 ? "" : "s")}";
            if (count == 0)
            {
                <div class="srs-level-item srs-level-item-disabled" title="No cards at this level">
                    <span class="srs-level-num">@levelNum</span>
                    <span class="srs-level-label">@label</span>
                    <span class="srs-level-count">@countText</span>
                </div>
            }
            else
            {
                <a class="srs-level-item" href="@($"training/srs/{levelNum}")">
                    <span class="srs-level-num">@levelNum</span>
                    <span class="srs-level-label">@label</span>
                    <span class="srs-level-count">@countText</span>
                </a>
            }
        }
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private static readonly SrsLevel[] _srsLevels = Enum.GetValues<SrsLevel>();
    private Dictionary<SrsLevel, int> _counts = new();
    private string _userId = string.Empty;
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        await LoadCountsAsync();
        _loaded = true;
    }

    private async Task LoadCountsAsync()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            _counts = new Dictionary<SrsLevel, int>();
            return;
        }
        var cards = await TermCardService.GetAllByUserAsync(_userId);
        _counts = _srsLevels.ToDictionary(l => l, l => cards.Count(c => c.SrsLevel == l));
    }

    private static string GetSrsLabel(SrsLevel level) => level switch
    {
        SrsLevel.Level1 => "Initial fixation",
        SrsLevel.Level2 => "Hold in short-term memory",
        SrsLevel.Level3 => "First step to mid-term memory",
        SrsLevel.Level4 => "Strengthen connection",
        SrsLevel.Level5 => "Stability check",
        SrsLevel.Level6 => "Transfer to long-term memory",
        SrsLevel.Level7 => "Long-term retention",
        _ => level.ToString()
    };
}

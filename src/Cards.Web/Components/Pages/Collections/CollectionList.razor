@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject ICollectionService CollectionService
@inject ITermCardService TermCardService
@inject NavigationManager Navigation

<PageTitle>Collections</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Collections</h1>
    <a class="btn btn-primary" href="collections/create">+ New collection</a>
</div>

@if (_collections is null)
{
    <p><em>Loading...</em></p>
}
else if (_collections.Count == 0)
{
    <div class="alert alert-info">
        You don't have any collections yet. <a href="collections/create">Create your first one</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Cards</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var col in _collections)
                {
                    <tr>
                        <td>
                            <strong>@col.Name</strong>
                            <br />
                            <small class="text-muted">
                                @LanguageHelper.GetPairDisplayName(col.Language1, col.Language2)
                            </small>
                        </td>
                        <td>@col.CardIds.Count</td>
                        <td>@col.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                <button type="button" class="btn btn-sm btn-outline-primary"
                                        @onclick="() => OpenAddCard(col)">
                                    + Card
                                </button>
                                @if (col.CardIds.Count > 0)
                                {
                                    <a class="btn btn-sm btn-success"
                                       href="@($"training/{col.Id}")">
                                        Train
                                    </a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-success" disabled>
                                        Train
                                    </button>
                                }
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        @onclick="() => AskDelete(col)">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_collectionToDelete is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete collection?</h5>
                </div>
                <div class="modal-body">
                    <p>The collection <strong>@_collectionToDelete.Name</strong> will be deleted.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_addCardCollection is not null)
{
    <TermCardModal
        UserId="_userId"
        Language1="_addCardCollection.Language1"
        Language2="_addCardCollection.Language2"
        OnSave="HandleCardSaved"
        OnSaveAndContinue="HandleCardSavedAndContinue"
        OnClose="CloseAddCard" />
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string _userId = string.Empty;
    private List<Collection>? _collections;
    private Collection? _collectionToDelete;
    private Collection? _addCardCollection;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        // Anonymous users have no own collections — redirect them to the public catalogue
        if (string.IsNullOrEmpty(_userId))
        {
            Navigation.NavigateTo("public");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await CollectionService.GetAllAsync(_userId);
        _collections = result.ToList();
    }

    private void OpenAddCard(Collection collection) => _addCardCollection = collection;
    private void CloseAddCard() => _addCardCollection = null;

    private async Task HandleCardSaved(TermCard card)
    {
        if (_addCardCollection is not null)
        {
            await CollectionService.AddCardAsync(_addCardCollection.Id, card.Id);
            _addCardCollection = null;
            await LoadAsync();
        }
    }

    private async Task HandleCardSavedAndContinue(TermCard card)
    {
        if (_addCardCollection is not null)
        {
            await CollectionService.AddCardAsync(_addCardCollection.Id, card.Id);
            await LoadAsync();
        }
    }

    private void AskDelete(Collection collection) => _collectionToDelete = collection;
    private void CancelDelete() => _collectionToDelete = null;

    private async Task ConfirmDelete()
    {
        if (_collectionToDelete is null) return;
        await CollectionService.DeleteAsync(_collectionToDelete.Id);
        _collectionToDelete = null;
        await LoadAsync();
    }
}

@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject ICollectionService CollectionService
@inject ITermCardService TermCardService
@inject NavigationManager Navigation

<PageTitle>Collections</PageTitle>

<div class="page-header">
    <h1>Collections</h1>
    <a class="btn btn-primary" href="collections/create">+ New collection</a>
</div>

@if (_collections is null)
{
    <p class="text-muted"><em>Loading...</em></p>
}
else if (_collections.Count == 0)
{
    <div class="alert alert-info">
        You don't have any collections yet. <a href="collections/create">Create your first one</a>.
    </div>
}
else
{
    <div class="surface-table table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Learning language</th>
                    <th>Native language</th>
                    <th>Cards</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var col in _collections)
                {
                    var canTrain = col.CardIds.Count > 0;
                    <tr class="@(canTrain ? "row-clickable" : null)"
                        @onclick="() => StartTraining(col)">
                        <td>
                            <div class="row-title">@col.Name</div>
                            <div class="row-subtitle">
                                @LanguageHelper.GetPairDisplayName(col.Language1, col.Language2)
                            </div>
                        </td>
                        <td>@LanguageHelper.GetDisplayName(col.Language1)</td>
                        <td>@LanguageHelper.GetDisplayName(col.Language2)</td>
                        <td>@col.CardIds.Count</td>
                        <td>@col.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td class="text-end" @onclick:stopPropagation="true">
                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                @if (col.CardIds.Count > 0)
                                {
                                    <a class="btn-icon btn-icon-train"
                                       href="@($"training/{col.Id}")"
                                       title="Train">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M8 5v14l11-7L8 5z" />
                                        </svg>
                                    </a>
                                }
                                else
                                {
                                    <button type="button" class="btn-icon btn-icon-train" disabled title="No cards yet">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M8 5v14l11-7L8 5z" />
                                        </svg>
                                    </button>
                                }
                                <button type="button" class="btn-icon btn-icon-add"
                                        @onclick="() => OpenAddCard(col)"
                                        title="Add card">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M11 5h2v6h6v2h-6v6h-2v-6H5v-2h6V5z" />
                                    </svg>
                                </button>
                                <a class="btn-icon btn-icon-edit"
                                   href="@($"collections/{col.Id}/edit")"
                                   title="Edit">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3 17.25V21h3.75l11.06-11.06-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                                    </svg>
                                </a>
                                <button type="button" class="btn-icon btn-icon-delete"
                                        @onclick="() => AskDelete(col)"
                                        title="Delete">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M9 3h6v2h5v2h-2v13a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V7H4V5h5V3zm1 6v9h2V9h-2zm4 0v9h2V9h-2z" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_collectionToDelete is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.65);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete collection?</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">The collection <strong>@_collectionToDelete.Name</strong> will be deleted.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_addCardCollection is not null)
{
    <TermCardModal
        UserId="@_userId"
        Language1="_addCardCollection.Language1"
        Language2="_addCardCollection.Language2"
        OnSave="HandleCardSaved"
        OnSaveAndContinue="HandleCardSavedAndContinue"
        OnClose="CloseAddCard" />
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string _userId = string.Empty;
    private List<Collection>? _collections;
    private Collection? _collectionToDelete;
    private Collection? _addCardCollection;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        // Anonymous users have no own collections — redirect them to the public catalogue
        if (string.IsNullOrEmpty(_userId))
        {
            Navigation.NavigateTo("public");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await CollectionService.GetAllAsync(_userId);
        _collections = result.ToList();
    }

    private void StartTraining(Collection collection)
    {
        if (collection.CardIds.Count == 0) return;
        Navigation.NavigateTo($"training/{collection.Id}");
    }

    private void OpenAddCard(Collection collection) => _addCardCollection = collection;
    private void CloseAddCard() => _addCardCollection = null;

    private async Task HandleCardSaved(TermCard card)
    {
        if (_addCardCollection is not null)
        {
            await CollectionService.AddCardAsync(_addCardCollection.Id, card.Id);
            _addCardCollection = null;
            await LoadAsync();
        }
    }

    private async Task HandleCardSavedAndContinue(TermCard card)
    {
        if (_addCardCollection is not null)
        {
            await CollectionService.AddCardAsync(_addCardCollection.Id, card.Id);
            await LoadAsync();
        }
    }

    private void AskDelete(Collection collection) => _collectionToDelete = collection;
    private void CancelDelete() => _collectionToDelete = null;

    private async Task ConfirmDelete()
    {
        if (_collectionToDelete is null) return;
        await CollectionService.DeleteAsync(_collectionToDelete.Id);
        _collectionToDelete = null;
        await LoadAsync();
    }
}

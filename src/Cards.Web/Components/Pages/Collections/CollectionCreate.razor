@page "/collections/create"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ICollectionService CollectionService
@inject ITermCardService TermCardService
@inject ITranslationService TranslationService
@inject NavigationManager Navigation

<PageTitle>New collection</PageTitle>

<div class="page-header">
    <h1>New collection</h1>
</div>

<div class="surface-card" style="max-width: 560px;">
    <EditForm Model="_model" OnValidSubmit="HandleValidSubmit" FormName="collection-create">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label" for="collection-name">Name</label>
            <InputText id="collection-name" class="form-control" @bind-Value="_model.Name" />
            <ValidationMessage For="@(() => _model.Name)" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="lang1">Learning language</label>
            <InputSelect id="lang1" class="form-select" @bind-Value="_model.Language1">
                @foreach (var lang in Enum.GetValues<Language>())
                {
                    <option value="@lang">@LanguageHelper.GetDisplayName(lang)</option>
                }
            </InputSelect>
        </div>

        <div class="mb-4">
            <label class="form-label" for="lang2">Native language</label>
            <InputSelect id="lang2" class="form-select" @bind-Value="_model.Language2">
                @foreach (var lang in Enum.GetValues<Language>())
                {
                    <option value="@lang">@LanguageHelper.GetDisplayName(lang)</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => _model.Language2)" />
        </div>

        <div class="mb-4">
            <label class="form-label" for="bulk-text">Bulk text (optional)</label>
            <InputTextArea id="bulk-text" class="form-control" rows="6"
                           @bind-Value="_model.BulkText"
                           placeholder="Paste text in the learning language. Each unique word with 4+ letters will become a card." />
            <div class="form-text text-muted mt-1">
                Words shorter than 4 letters and duplicates are skipped. Each remaining word is auto-translated into the native language; words that fail to translate are skipped.
            </div>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @(_saving ? "Creating..." : "Create")
            </button>
            <a class="btn btn-outline-secondary" href="">Cancel</a>
            @if (_saving && _bulkTotal > 0)
            {
                <span class="text-muted small ms-2">
                    Creating cards: @_bulkProcessed / @_bulkTotal
                </span>
            }
        </div>
    </EditForm>
</div>

@code {
    private const int MinWordLength = 4;

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private readonly CollectionFormModel _model = new()
    {
        Language1 = Language.Ru,
        Language2 = Language.En
    };

    private bool _saving;
    private int _bulkProcessed;
    private int _bulkTotal;

    private async Task HandleValidSubmit()
    {
        if (_model.Language1 == _model.Language2) return;

        _saving = true;
        _bulkProcessed = 0;
        _bulkTotal = 0;
        try
        {
            var state = await AuthStateTask;
            var userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
            var collection = await CollectionService.CreateAsync(userId, _model.Name, _model.Language1, _model.Language2);

            if (!string.IsNullOrWhiteSpace(_model.BulkText))
            {
                await PopulateCardsFromBulkAsync(userId, collection.Id, _model.BulkText);
            }

            Navigation.NavigateTo("");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task PopulateCardsFromBulkAsync(string userId, Guid collectionId, string text)
    {
        var words = ExtractWords(text);
        _bulkTotal = words.Count;
        StateHasChanged();

        foreach (var word in words)
        {
            var translation = await TranslationService.TranslateAsync(word, _model.Language1, _model.Language2);
            // Skip words for which translation failed or returned empty
            if (!string.IsNullOrWhiteSpace(translation))
            {
                var card = await TermCardService.CreateAsync(
                    userId,
                    _model.Language1, _model.Language2,
                    word, translation,
                    imageDataUrl: null,
                    audio1Base64: null);
                await CollectionService.AddCardAsync(collectionId, card.Id);
            }

            _bulkProcessed++;
            StateHasChanged();
        }
    }

    // Splits text into unique words (case-insensitive) of MinWordLength letters or more,
    // preserving the order of first appearance.
    private static List<string> ExtractWords(string text)
    {
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var result = new List<string>();
        var current = new System.Text.StringBuilder();

        foreach (var ch in text)
        {
            if (char.IsLetter(ch))
            {
                current.Append(ch);
            }
            else if (current.Length > 0)
            {
                AppendIfEligible(current, seen, result);
                current.Clear();
            }
        }

        if (current.Length > 0)
            AppendIfEligible(current, seen, result);

        return result;
    }

    private static void AppendIfEligible(
        System.Text.StringBuilder buffer,
        HashSet<string> seen,
        List<string> result)
    {
        if (buffer.Length < MinWordLength) return;
        var word = buffer.ToString();
        if (seen.Add(word))
            result.Add(word);
    }

    public class CollectionFormModel : IValidatableObject
    {
        [Required(ErrorMessage = "Enter a name")]
        [StringLength(100, ErrorMessage = "Maximum 100 characters")]
        public string Name { get; set; } = string.Empty;

        public Language Language1 { get; set; }

        public Language Language2 { get; set; }

        public string BulkText { get; set; } = string.Empty;

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (Language1 == Language2)
                yield return new ValidationResult("Languages must be different", new[] { nameof(Language2) });
        }
    }
}
